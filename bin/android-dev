#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
android-dev: lightweight Android development workflow from the terminal

Usage:
  android-dev help
  android-dev doctor
  android-dev build [gradle-task]
  android-dev clean
  android-dev install [gradle-task]
  android-dev apk [variant]
  android-dev run [variant] [device-serial]
  android-dev test unit [gradle-task]
  android-dev test android [gradle-task]
  android-dev emulator list
  android-dev emulator start <avd-name>
  android-dev emulator stop <avd-name>
  android-dev sdk list
  android-dev sdk install <package>...
  android-dev sdk update [package]
  android-dev sdk remove <package>
  android-dev screen [output.png] [device-serial]
  android-dev layout [device-serial]
  android-dev logcat [device-serial]

Notes:
  - Run project commands from anywhere inside an Android Gradle project.
  - Default build task is assembleDebug.
  - Default install task is installDebug.
  - Default APK variant is debug.
EOF
}

die() {
  printf 'android-dev: %s\n' "$*" >&2
  exit 1
}

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

sdk_dir() {
  if has_cmd android; then
    android info sdk 2>/dev/null | tail -n 1
  elif [[ -n "${ANDROID_SDK_ROOT:-}" ]]; then
    printf '%s\n' "$ANDROID_SDK_ROOT"
  elif [[ -n "${ANDROID_HOME:-}" ]]; then
    printf '%s\n' "$ANDROID_HOME"
  fi
}

resolve_adb() {
  local sdk

  if has_cmd adb; then
    command -v adb
    return 0
  fi

  sdk="$(sdk_dir || true)"
  if [[ -n "$sdk" && -x "$sdk/platform-tools/adb" ]]; then
    printf '%s\n' "$sdk/platform-tools/adb"
    return 0
  fi

  return 1
}

find_project_root() {
  local dir
  dir="${PWD}"

  while [[ "$dir" != "/" ]]; do
    if [[ -x "$dir/gradlew" ]] || [[ -f "$dir/settings.gradle" ]] || [[ -f "$dir/settings.gradle.kts" ]]; then
      printf '%s\n' "$dir"
      return 0
    fi
    dir="$(dirname "$dir")"
  done

  return 1
}

require_project() {
  PROJECT_ROOT="$(find_project_root)" || die "not inside an Android Gradle project"
  GRADLEW="$PROJECT_ROOT/gradlew"
  [[ -x "$GRADLEW" ]] || die "missing executable gradlew at $GRADLEW"
}

run_gradle() {
  require_project
  (cd "$PROJECT_ROOT" && "$GRADLEW" "$@")
}

variant_to_task_suffix() {
  local variant=${1:-debug}
  local first rest
  first="${variant:0:1}"
  rest="${variant:1}"
  printf '%s%s\n' "${first^^}" "$rest"
}

find_apk() {
  require_project
  local variant apk
  variant="${1:-debug}"

  apk="$(find "$PROJECT_ROOT" -path "*/build/outputs/apk/$variant/*.apk" ! -name "*-unsigned.apk" | head -n 1 || true)"
  [[ -n "$apk" ]] || die "no APK found for variant '$variant'. Run: android-dev build assemble$(variant_to_task_suffix "$variant")"
  printf '%s\n' "$apk"
}

cmd_doctor() {
  local adb_bin
  printf 'Android CLI:\n'
  android --version
  printf '\nAndroid Info:\n'
  android info

  printf '\nTooling:\n'
  adb_bin="$(resolve_adb || true)"
  if [[ -n "$adb_bin" ]]; then
    "$adb_bin" version | head -n 1
  else
    printf 'adb: not found\n'
  fi

  if has_cmd java; then
    java -version 2>&1 | head -n 1
  else
    printf 'java: not found\n'
  fi

  printf '\nAVDs:\n'
  android emulator list || true

  if PROJECT_ROOT="$(find_project_root 2>/dev/null)"; then
    printf '\nProject: %s\n' "$PROJECT_ROOT"
    if [[ -x "$PROJECT_ROOT/gradlew" ]]; then
      (cd "$PROJECT_ROOT" && ./gradlew -q tasks --all | sed -n '1,40p') || printf 'Gradle task listing skipped because the environment rejected the daemon startup.\n'
    fi
  else
    printf '\nProject: none detected from current directory\n'
  fi
}

cmd_build() {
  local task
  task="${1:-assembleDebug}"
  run_gradle "$task"
}

cmd_clean() {
  run_gradle clean
}

cmd_install() {
  local task
  task="${1:-installDebug}"
  run_gradle "$task"
}

cmd_apk() {
  local variant
  variant="${1:-debug}"
  find_apk "$variant"
}

cmd_run() {
  local variant device apk build_task
  variant="${1:-debug}"
  device="${2:-}"
  build_task="assemble$(variant_to_task_suffix "$variant")"

  run_gradle "$build_task"
  apk="$(find_apk "$variant")"

  if [[ -n "$device" ]]; then
    android run --device="$device" --apks="$apk"
  else
    android run --apks="$apk"
  fi
}

cmd_test() {
  local mode task
  mode="${1:-}"
  case "$mode" in
    unit)
      task="${2:-test}"
      run_gradle "$task"
      ;;
    android)
      task="${2:-connectedAndroidTest}"
      run_gradle "$task"
      ;;
    *)
      die "test mode must be 'unit' or 'android'"
      ;;
  esac
}

cmd_emulator() {
  local action name
  action="${1:-}"
  name="${2:-}"

  case "$action" in
    list)
      android emulator list
      ;;
    start)
      [[ -n "$name" ]] || die "missing AVD name"
      android emulator start "$name"
      ;;
    stop)
      [[ -n "$name" ]] || die "missing AVD name"
      android emulator stop "$name"
      ;;
    *)
      die "emulator action must be one of: list, start, stop"
      ;;
  esac
}

cmd_sdk() {
  local action
  action="${1:-}"
  shift || true

  case "$action" in
    list)
      android sdk list --all
      ;;
    install)
      [[ $# -gt 0 ]] || die "provide at least one package to install"
      android sdk install "$@"
      ;;
    update)
      if [[ $# -gt 0 ]]; then
        android sdk update "$1"
      else
        android sdk update
      fi
      ;;
    remove)
      [[ $# -gt 0 ]] || die "provide a package to remove"
      android sdk remove "$1"
      ;;
    *)
      die "sdk action must be one of: list, install, update, remove"
      ;;
  esac
}

cmd_screen() {
  local output device
  output="${1:-$HOME/Pictures/android-screen-$(date +%F-%H%M%S).png}"
  device="${2:-}"

  if [[ -n "$device" ]]; then
    android screen capture --device="$device" "$output"
  else
    android screen capture "$output"
  fi
}

cmd_layout() {
  local device
  device="${1:-}"

  if [[ -n "$device" ]]; then
    android layout --device="$device" --pretty
  else
    android layout --pretty
  fi
}

cmd_logcat() {
  local device adb_bin
  device="${1:-}"
  adb_bin="$(resolve_adb || true)"
  [[ -n "$adb_bin" ]] || die "adb is not installed or not on PATH"

  if [[ -n "$device" ]]; then
    "$adb_bin" -s "$device" logcat
  else
    "$adb_bin" logcat
  fi
}

main() {
  has_cmd android || die "'android' CLI not found on PATH"

  local command
  command="${1:-help}"
  shift || true

  case "$command" in
    help|-h|--help)
      usage
      ;;
    doctor)
      cmd_doctor "$@"
      ;;
    build)
      cmd_build "$@"
      ;;
    clean)
      cmd_clean "$@"
      ;;
    install)
      cmd_install "$@"
      ;;
    apk)
      cmd_apk "$@"
      ;;
    run)
      cmd_run "$@"
      ;;
    test)
      cmd_test "$@"
      ;;
    emulator)
      cmd_emulator "$@"
      ;;
    sdk)
      cmd_sdk "$@"
      ;;
    screen)
      cmd_screen "$@"
      ;;
    layout)
      cmd_layout "$@"
      ;;
    logcat)
      cmd_logcat "$@"
      ;;
    *)
      usage
      die "unknown command '$command'"
      ;;
  esac
}

main "$@"
